pipeline {
    agent any

    tools {
        nodejs 'node20'
    }

    environment {
        APP_DIR = 'devops-monitoring-portal'
        APP_NAME = 'devops-monitoring-portal'
        K8S_NODE = 'desktop-control-plane'
        SONAR_SCANNER_HOME = tool 'sonar-scanner'
        PATH = "/opt/homebrew/bin:/usr/local/bin:${env.PATH}"
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20', artifactNumToKeepStr: '10'))
        timeout(time: 45, unit: 'MINUTES')
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Preflight') {
            steps {
                dir(env.APP_DIR) {
                    sh 'chmod +x scripts/preflight.sh && K8S_NODE=${K8S_NODE} ./scripts/preflight.sh'
                }
            }
        }

        stage('Trivy File System Scan') {
            steps {
                dir(env.APP_DIR) {
                    sh '''
                        trivy fs --severity HIGH,CRITICAL --exit-code 0 \
                          --skip-dirs node_modules,coverage,.git,kubernetes,scripts,data \
                          --format json -o trivyfs.json .
                        node scripts/format-trivy-report.js trivyfs.json > trivyfs.txt
                    '''
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir(env.APP_DIR) {
                    sh 'npm ci'
                }
            }
        }

        stage('Unit Test') {
            steps {
                dir(env.APP_DIR) {
                    sh 'npm test'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir(env.APP_DIR) {
                    withSonarQubeEnv('sonar-server') {
                        sh '''
                            $SONAR_SCANNER_HOME/bin/sonar-scanner \
                            -Dsonar.projectKey=devops-monitoring-portal \
                            -Dsonar.projectName=devops-monitoring-portal \
                            -Dsonar.sources=src \
                            -Dsonar.tests=tests \
                            -Dsonar.exclusions=node_modules/**,coverage/**,public/**
                        '''
                    }
                }
            }
        }

        stage('SonarQube Quality Gate') {
            steps {
                catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                    timeout(time: 5, unit: 'MINUTES') {
                        script {
                            def qg = waitForQualityGate abortPipeline: false
                            env.SONAR_QUALITY_GATE = qg.status
                            echo "SonarQube quality gate status: ${qg.status}"
                        }
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir(env.APP_DIR) {
                    sh '''
                        docker build \
                          -t ${APP_NAME}:${BUILD_NUMBER} \
                          -t ${APP_NAME}:latest \
                          .
                    '''
                }
            }
        }

        stage('Trivy Image Scan') {
            steps {
                dir(env.APP_DIR) {
                    sh '''
                        trivy image --severity HIGH,CRITICAL --exit-code 0 \
                          --format json -o trivyimage.json ${APP_NAME}:${BUILD_NUMBER}
                        node scripts/format-trivy-report.js trivyimage.json > trivyimage.txt
                    '''
                }
            }
        }

        stage('Load Image into Kubernetes Node') {
            steps {
                dir(env.APP_DIR) {
                    sh '''
                        chmod +x scripts/load-image-k8s.sh
                        ./scripts/load-image-k8s.sh ${APP_NAME} ${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('Deploy to Local Kubernetes') {
            steps {
                dir(env.APP_DIR) {
                    sh '''
                        kubectl apply -f kubernetes/
                        kubectl apply -f kubernetes/monitoring/
                        kubectl set image deployment/devops-monitoring-portal \
                          devops-monitoring-portal=${APP_NAME}:${BUILD_NUMBER}
                        kubectl rollout status deployment/devops-monitoring-portal --timeout=5m
                        kubectl rollout status deployment/prometheus --timeout=5m
                        kubectl rollout status deployment/grafana --timeout=5m
                    '''
                }
            }
        }

        stage('Verify Deployment') {
            steps {
                dir(env.APP_DIR) {
                    sh '''
                        kubectl get pods
                        kubectl get deployments
                        kubectl get svc
                        READY=$(kubectl get pods -l app=devops-monitoring-portal -o jsonpath='{.items[*].status.conditions[?(@.type=="Ready")].status}' | tr ' ' '\n' | grep -c '^True$' || true)
                        TOTAL=$(kubectl get pods -l app=devops-monitoring-portal --no-headers 2>/dev/null | wc -l | tr -d ' ')
                        echo "K8S_PODS_READY=${READY}" > k8s-pods.env
                        echo "K8S_PODS_TOTAL=${TOTAL}" >> k8s-pods.env
                    '''
                }
            }
        }

        stage('Smoke Test') {
            steps {
                dir(env.APP_DIR) {
                    sh 'chmod +x scripts/smoke-k8s.sh && ./scripts/smoke-k8s.sh'
                }
            }
        }

        stage('Verify Monitoring') {
            steps {
                sh '''
                    kubectl wait --for=condition=available deployment/prometheus --timeout=120s
                    kubectl wait --for=condition=available deployment/grafana --timeout=120s

                    kubectl exec deploy/prometheus -- wget -qO- \
                        'http://localhost:9090/api/v1/query?query=app_uptime_seconds' \
                        | grep -q '"status":"success"'

                    kubectl exec deploy/grafana -- wget -qO- http://localhost:3000/api/health \
                        | grep -Eq '"database"[[:space:]]*:[[:space:]]*"ok"'

                    echo "Monitoring verification passed: Prometheus query OK, Grafana healthy"
                '''
            }
        }

        stage('Verify Local Access') {
            steps {
                dir(env.APP_DIR) {
                    sh '''
                        chmod +x scripts/verify-local-access.sh
                        export DEBUG_LOG="${WORKSPACE}/.cursor/debug-dfd10b.log"
                        export DEBUG_RUN_ID="jenkins-${BUILD_NUMBER}"
                        mkdir -p "$(dirname "${DEBUG_LOG}")"
                        ./scripts/verify-local-access.sh
                    '''
                }
            }
        }
    }

    post {
        always {
            script {
                env.BUILD_RESULT = "${currentBuild.currentResult}"
                env.BUILD_DURATION_MS = "${currentBuild.duration ?: 0}"
            }
            dir(env.APP_DIR) {
                sh '''
                    set +e
                    curl -sf "${BUILD_URL}wfapi/describe" -o /tmp/wfapi.json || echo '{"stages":[]}' > /tmp/wfapi.json
                    curl -sf "${JENKINS_URL}job/${JOB_NAME}/api/json?tree=builds[number,result,timestamp]{0,10}" -o /tmp/builds.json || echo '{"builds":[]}' > /tmp/builds.json

                    if [ -f k8s-pods.env ]; then . ./k8s-pods.env; fi

                    node scripts/summarize-trivy.js trivyfs.json trivyimage.json > /tmp/trivy-summary.json

                    APP_VERSION=$(node -p "require('./package.json').version")

                    WFAPI_JSON_PATH=/tmp/wfapi.json \
                    BUILDS_JSON_PATH=/tmp/builds.json \
                    TRIVY_SUMMARY_JSON=/tmp/trivy-summary.json \
                    BUILD_NUMBER="${BUILD_NUMBER}" \
                    BUILD_URL="${BUILD_URL}" \
                    JOB_NAME="${JOB_NAME}" \
                    BUILD_RESULT="${BUILD_RESULT}" \
                    BUILD_DURATION_MS="${BUILD_DURATION_MS}" \
                    K8S_PODS_READY="${K8S_PODS_READY:-0}" \
                    K8S_PODS_TOTAL="${K8S_PODS_TOTAL:-0}" \
                    APP_VERSION="${APP_VERSION}" \
                    IMAGE_TAG="${BUILD_NUMBER}" \
                    SONAR_QUALITY_GATE="${SONAR_QUALITY_GATE:-}" \
                    OUTPUT_PATH=data/pipeline-status.json \
                    node scripts/generate-pipeline-status.js

                    kubectl create configmap pipeline-status \
                      --from-file=pipeline-status.json=data/pipeline-status.json \
                      --dry-run=client -o yaml | kubectl apply -f -

                    kubectl rollout restart deployment/devops-monitoring-portal
                    kubectl rollout status deployment/devops-monitoring-portal --timeout=5m || true
                '''
            }
            archiveArtifacts artifacts: "${APP_DIR}/trivyfs.txt,${APP_DIR}/trivyimage.txt,${APP_DIR}/trivyfs.json,${APP_DIR}/trivyimage.json,${APP_DIR}/data/pipeline-status.json", allowEmptyArchive: true
        }
        success {
            echo 'Local DevSecOps pipeline completed successfully.'
            echo 'App:        http://localhost:30080'
            echo 'Prometheus: http://localhost:9091  (9090 kept free for local Prometheus installs)'
            echo 'Grafana:    http://localhost:3030  (login admin/admin)'
        }
        failure {
            echo "Pipeline failed (result: ${currentBuild.result}). Check the stage above that returned a non-zero exit code."
            echo 'Archived Trivy reports are under this build Artifacts tab (trivyfs.txt, trivyimage.txt).'
            echo 'Troubleshooting:'
            echo '  - Preflight: docker info, kubectl cluster-info, trivy --version'
            echo '  - K8s node:  docker ps --filter name=desktop-control-plane'
            echo '  - Jenkins:   node20 tool, sonar-server credential, Script Path to this Jenkinsfile'
            echo '  - Smoke:     kubectl get pods -l app=devops-monitoring-portal'
            echo 'See README.md for full local setup steps.'
        }
    }
}
